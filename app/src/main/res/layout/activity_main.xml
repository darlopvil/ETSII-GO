<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layout_actividad_principal"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">


    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guia_horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.5" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guia_vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5" />

    <Button
        android:id="@+id/boton_gps_facultad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/boton_gps_facultad"
        app:layout_constraintBottom_toTopOf="@+id/guia_horizontal"
        app:layout_constraintEnd_toStartOf="@+id/guia_vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/boton_servicios"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/boton_servicios"
        app:layout_constraintBottom_toTopOf="@+id/guia_horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/guia_vertical"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/boton_itinerario"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/boton_itinerario"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/guia_vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/guia_horizontal" />

    <Button
        android:id="@+id/boton_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/boton_info"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/guia_vertical"
        app:layout_constraintTop_toTopOf="@+id/guia_horizontal" />
</androidx.constraintlayout.widget.ConstraintLayout>